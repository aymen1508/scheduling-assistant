# ============================================================================
# Azure VoiceLive Configuration (REQUIRED)
# ============================================================================
# Get these from the Azure AI Foundry console
# https://ai.azure.com

# VoiceLive endpoint URL
# Format: https://{resource-name}.services.ai.azure.com/
AZURE_VOICELIVE_ENDPOINT="https://your-resource.services.ai.azure.com/"

# Agent ID (agent-name:version or just agent-name)
# Format: agent-name:version or agent-name (will use latest)
AZURE_VOICELIVE_AGENT_ID="your-agent-name"

# Project name in Azure AI Foundry
AZURE_VOICELIVE_PROJECT_NAME="your-project-name"

# API version for VoiceLive service
AZURE_VOICELIVE_API_VERSION="2025-10-01"


# ============================================================================
# Azure Resource Configuration (Optional but recommended)
# ============================================================================
# Used for advanced deployments and resource management

# Environment name for the deployment
# AZURE_ENV_NAME="your-environment-name"

# Azure location/region (e.g., eastus, swedencentral, westeurope)
# AZURE_LOCATION="your-region"

# Your Azure subscription ID
# AZURE_SUBSCRIPTION_ID="your-subscription-id"

# AI Project endpoint (fully qualified URL)
# AZURE_EXISTING_AIPROJECT_ENDPOINT="https://your-resource.services.ai.azure.com/api/projects/your-project-name"

# AI Project resource ID (full resource path)
# AZURE_EXISTING_AIPROJECT_RESOURCE_ID="/subscriptions/your-subscription-id/resourceGroups/your-resource-group/providers/Microsoft.CognitiveServices/accounts/your-account-name"

# AZD (Azure Developer CLI) flag
# Set to true if deploying with non-empty folder
# AZD_ALLOW_NON_EMPTY_FOLDER=true


# ============================================================================
# VoiceLive Session Configuration (Optional)
# ============================================================================
# For advanced conversational control

# Specific agent version if different from ID
# AZURE_VOICELIVE_AGENT_VERSION=""

# Conversation ID to resume a previous conversation
# AZURE_VOICELIVE_CONVERSATION_ID="your-conversation-id"

# Foundry resource override for accessing another resource
# AZURE_VOICELIVE_FOUNDRY_RESOURCE_OVERRIDE="your-foundry-resource"

# Authentication identity client ID for specific access control
# AZURE_VOICELIVE_AUTH_IDENTITY_CLIENT_ID="your-client-id"


# ============================================================================
# Calendar Integration (Optional)
# ============================================================================
# For calendar event creation functionality
# Note: Calendar MCP tools are configured in the Azure AI agent itself

# Google Calendar service account credentials (if using external calendar)
# Format: {"type":"service_account","project_id":"...","private_key":"..."}
# Get from Google Cloud Console > Service Accounts
# GOOGLE_CALENDAR_CREDENTIALS=""


# ============================================================================
# Application Configuration (Optional)
# ============================================================================
# Settings for local development and deployment

# Gradio server port (local development)
# PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Enable debug mode (shows detailed errors)
# DEBUG=false
